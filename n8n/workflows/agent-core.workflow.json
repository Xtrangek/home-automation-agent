        "jsCode": "const items = $input.all();\nconst results = items.map(item => item.json);\n\n// Consolida los resultados\nconst message = `✅ Comando ejecutado con éxito.\\n\\n` +\n  results.map((r, i) => \n    `Dispositivo ${i + 1}:\\n` +\n    `• Salida: ${r.stdout || 'Sin salida'}\\n` +\n    `• Estado: ${r.stderr || 'Completado'}`\n  ).join('\\n\\n');\n\nreturn { consolidated_message: message };"
      },
