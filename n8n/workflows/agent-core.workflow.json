    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// 🔥 obtener chat_id correctamente\nconst chatId = $node[\"Telegram Trigger\"].json[\"message\"][\"chat\"][\"id\"].toString();\n\nconst now = Date.now();\nconst timeoutMs = 15 * 60 * 1000;\n\nif (!staticData.lastSeenByChat) {\n  staticData.lastSeenByChat = {};\n}\n\nconst lastSeen = staticData.lastSeenByChat[chatId] || 0;\nconst sendGreeting = (now - lastSeen) > timeoutMs;\n\n// actualizar última interacción\nstaticData.lastSeenByChat[chatId] = now;\n\nreturn [\n  {\n    json: {\n      ...$json,\n      sendGreeting,\n      chat_id: chatId,\n      sessionKey: chatId\n    }\n  }\n];"
      },
