    {
      "parameters": {
        "jsCode": "// ==========================\n// 1. PARSEAR RESPUESTA DEL LLM\n// ==========================\nconst raw = $json.llm_response;\n\nlet parsed;\ntry {\n  // Intentamos limpiar la respuesta por si el LLM incluye backticks de markdown\n  const cleanRaw = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleanRaw);\n} catch (e) {\n  parsed = {\n    action: 'answer',\n    command: null,\n    message: 'Error al parsear la respuesta del agente: ' + raw\n  };\n}\n\n// ==========================\n// 2. PROCESAR MEMORIA\n// ==========================\nconst memoryRaw = $json.memory;\nlet memory;\n\ntry {\n  if (typeof memoryRaw === \"string\") {\n    memory = JSON.parse(memoryRaw);\n  } else {\n    memory = memoryRaw;\n  }\n} catch (e) {\n  memory = {\n    last_app: null,\n    last_action: null,\n    status: \"idle\",\n    mode: \"normal\"\n  };\n}\n\n// ==========================\n// 3. LOGICA DE COMANDO DINÁMICO\n// ==========================\n// Aseguramos que 'command' exista para que el nodo SSH no falle\nconst finalCommand = parsed.command || null;\n\n// ==========================\n// 4. RETURN FINAL (UNIFICADO)\n// ==========================\nreturn [\n  {\n    json: {\n      action: parsed.action || 'answer',\n      command: finalCommand,\n      message: parsed.message || '',\n      memory: memory,\n      chat_id: $json.chat_id\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
