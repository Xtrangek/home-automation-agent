    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nconst chatId = $json.message.chat.id.toString();\nconst now = Date.now();\n\n// cambia este valor a lo que quieras\nconst timeoutMs = 15 * 60 * 1000; // 15 minutos\n\nif (!staticData.lastSeenByChat) {\n  staticData.lastSeenByChat = {};\n}\n\nconst lastSeen = staticData.lastSeenByChat[chatId] || 0;\nconst sendGreeting = (now - lastSeen) > timeoutMs;\n\n// actualizamos la última actividad\nstaticData.lastSeenByChat[chatId] = now;\n\nreturn [\n  {\n    json: {\n      ...$json,\n      sendGreeting,\n      chat_id: $json.message.chat.id,\n      sessionKey: chatId,\n    }\n  }\n];"
      },
