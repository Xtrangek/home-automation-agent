{
  "telegram": {
    "type": "telegramApi",
    "note": "Create a Telegram credential in n8n using your bot token",
    "fields": {
      "accessToken": "YOUR_TELEGRAM_BOT_TOKEN"
    }
  },
  "ssh": {
    "type": "ssh",
    "note": "Used to execute commands on host",
    "fields": {
      "host": "host.docker.internal",
      "user": "ony",
      "authentication": "privateKey",
      "privateKey": "PATH_TO_KEY"
    }
  },
  "ollama": {
    "type": "http",
    "note": "Local Ollama endpoint",
    "fields": {
      "baseUrl": "http://ollama:11434"
    }
  }
}